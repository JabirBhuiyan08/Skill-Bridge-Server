generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(225)
  description String
  authorId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  subjects    Subject[]
}

model Booking {
  id        String   @id @default(uuid())
  duration  String
  location  String
  studentId String
  tutorId   String
  createdAt DateTime @default(now())
  student   User     @relation("StudentBooking", fields: [studentId], references: [id])
  tutor     User     @relation("TutorBooking", fields: [tutorId], references: [id])
  reviews   Review[] @relation("BookingReview")
}

model Review {
  id         String   @id @default(uuid())
  bookingId  String
  studentId  String
  tutorId    String
  rating     Int
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  booking    Booking  @relation("BookingReview", fields: [bookingId], references: [id])
  student    User     @relation("StudentReview", fields: [studentId], references: [id])
  tutor      User     @relation("TutorReview", fields: [tutorId], references: [id])
}

model Availability {
  id           String   @id @default(uuid())
  tutorId      String
  subjectId    String
  name         String
  description  String
  dayOfWeek    String
  startTime    String
  endTime      String
  slotDuration String
  isActive     Boolean
  // Pricing: optional amount (float) and currency code (e.g. "usd")
  priceAmount  Float?
  currency     String?
  createdAt    DateTime @default(now())
  tutor        User     @relation(fields: [tutorId], references: [id])
  subject      Subject  @relation(fields: [subjectId], references: [id])
}

model TutorSubject {
  id                String   @id @default(uuid())
  tutorId           String
  subjectId         String
  proficiencyLevel  String
  yearsOfExperience String
  createdAt         DateTime @default(now())
  tutor             Tutor    @relation(fields: [tutorId], references: [id])
  subject           Subject  @relation(fields: [subjectId], references: [id])
}

model Tutor {
  id             String         @id @default(uuid())
  userId         String         @unique
  name           String
  email          String         @unique
  bio            String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id])
  tutorSubjects  TutorSubject[]
}

model Subject {
  id            String        @id @default(uuid())
  categoryId    String
  name          String
  description   String
  category      Category      @relation(fields: [categoryId], references: [id])
  tutorSubjects TutorSubject[]
  availabilities Availability[]
}

model User {
  id              String         @id
  name            String
  email           String         @unique
  emailVerified   Boolean        @default(false)
  image           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  role            UserRole?      @default(STUDENT)
  phone           String?
  status          String?        @default("ACTIVE")
  studentBookings Booking[]      @relation("StudentBooking")
  tutorBookings   Booking[]      @relation("TutorBooking")
  givenReviews    Review[]       @relation("StudentReview")
  receivedReviews Review[]       @relation("TutorReview")
  tutor           Tutor?
  availabilities  Availability[]
  accounts        Account[]
  sessions        Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now())
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())

  @@index([identifier])
  @@map("verification")
}

enum UserRole {
  STUDENT
  TUTOR
  ADMIN
}