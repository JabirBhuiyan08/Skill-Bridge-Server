generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id String @id @default(uuid())
  name String @db.VarChar(225)
  description String @db.Text
  authorId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subject Subject[]
}

model Booking {
  id String @id @default(uuid())
  studentId String
  tutorId String
  subjectId String
  startTime DateTime
  endTime DateTime
  duration String
  location String
  createdAt DateTime @default(now())
  completedAt DateTime @default(now())
  @@index([tutorId])
}

model Review{
  id String @id @default(uuid())
  bookingId String
  studentId String
  tutorId String
  subjectId String
  rating String
  comment String
  isApproved Boolean
  createdAt DateTime @default(now())
  @@index([tutorId])
}

model Avaiability{
  id String @id @default(uuid())
  tutorId String
  subjectId String
  name String
  description String @db.Text
  dayOfWeek String 
  startTime String
  endTime String
  slotDuration String
  isActive Boolean
  createdAt DateTime @default(now())
}

model TutorSubject {
  id String @id @default(uuid())
  tutorId String
  proficiencyLevel String
  yearsOfExperience String
  createdAt DateTime @default(now())
}

model Subject {
  id String @id @default(uuid())
  categoryId String
  category Category @relation(fields: [categoryId], references: [id])
  name String
  description String
}



