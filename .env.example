# Backend Environment Variables Template
# Copy this to .env file and fill in your values

# ========== APPLICATION SETTINGS ==========
NODE_ENV=production
PORT=5000

# ========== FRONTEND URL (CRITICAL FOR CORS) ==========
# This MUST match your frontend URL exactly
# For production:
APP_URL=https://assignment4frontend-gvu9.vercel.app

# ========== DATABASE ==========
# Set this based on your database provider
DATABASE_URL=your_database_connection_string_here

# ========== AUTHENTICATION (if using better-auth) ==========
BETTER_AUTH_SECRET=your_secret_key_here

# ========== EMAIL SERVICE (if using nodemailer) ==========
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# ========== VERCEL ==========
# This is automatically set by Vercel, but listed for reference
# VERCEL=1
# VERCEL_ENV=production

# ========== DEBUG ==========
# Set to true to see CORS rejection logs
DEBUG=true
